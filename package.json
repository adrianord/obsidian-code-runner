{
  "name": "obsidian-code-runner",
  "version": "0.1.0",
  "description": "Lightweight notebook-style code execution for Obsidian Live Preview.",
  "main": "main.js",
  "type": "module",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.16.5",
    "esbuild": "0.25.5",
    "tslib": "2.7.0",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "@babel/runtime": "^7.29.2",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/legacy-modes": "^6.5.2",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@lezer/highlight": "^1.2.3",
    "@uiw/codemirror-theme-dracula": "^4.25.9",
    "@uiw/codemirror-theme-github": "^4.25.9",
    "@uiw/codemirror-theme-nord": "^4.25.9",
    "@uiw/codemirror-theme-quietlight": "^4.25.9",
    "@uiw/codemirror-theme-tokyo-night": "^4.25.9",
    "@uiw/codemirror-theme-xcode": "^4.25.9",
    "obsidian": "latest"
  }
}
